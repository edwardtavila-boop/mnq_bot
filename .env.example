# Tradovate paper credentials
# Get these by signing up at https://trader.tradovate.com (sign up free,
# request API access at https://api.tradovate.com under your profile)
TV_USERNAME=your_username_here
TV_PASSWORD=your_password_here
TV_APP_ID=YourAppName
TV_APP_VERSION=0.0.1
TV_DEVICE_ID=replace-with-uuid4
TV_CID=                          # supplied by Tradovate when you register the app
TV_SEC=                          # supplied by Tradovate when you register the app

# Environment: 'demo' for paper, 'live' for funded.
# We design+test against demo; do not flip to live without going through the
# 8-level pyramid AND the 90-day shadow validation AND the human promotion
# checklist in docs/RUNBOOK.md.
TV_ENV=demo

# Account ID — the integer ID of the paper account to trade on. Look it up
# once with `mnq venue tradovate list-accounts` after auth works.
TV_ACCOUNT_ID=

# Storage
DUCKDB_PATH=./data/mnq.duckdb
PARQUET_BARS_DIR=./data/bars
PARQUET_TICKS_DIR=./data/ticks
WEBHOOK_LOG_PATH=./logs/webhook.jsonl
EXECUTOR_LOG_PATH=./logs/executor.jsonl

# MCP server
MCP_TRANSPORT=stdio              # stdio | sse
MCP_BIND=127.0.0.1:8765          # only used if MCP_TRANSPORT=sse

# Pine webhook receiver (separate process; see scripts/run_webhook.py)
WEBHOOK_BIND=127.0.0.1:8443
WEBHOOK_HMAC_SECRET=             # match this exact string in TV alert body

# Risk / safety
KILL_SWITCH_REQUIRES_DOUBLE_CONFIRM=true
EMERGENCY_FLATTEN_SMS_TO=        # phone number for level-3 kill alerts (optional)
